<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FIFA World Cup 2026 — Live Bracket Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --blue-deep: #1a3a5c;
  --blue-mid: #2b6cb0;
  --blue-light: #4299e1;
  --green-pitch: #2f855a;
  --green-light: #48bb78;
  --orange-gold: #dd6b20;
  --orange-light: #ed8936;
  --yellow-stadium: #ecc94b;
  --red-card: #e53e3e;
  --white: #ffffff;
  --gray-50: #f7fafc;
  --gray-100: #edf2f7;
  --gray-200: #e2e8f0;
  --gray-400: #a0aec0;
  --gray-600: #718096;
  --gray-800: #2d3748;
  --radius: 12px;
  --shadow: 0 4px 24px rgba(26,58,92,0.10);
  --shadow-lg: 0 8px 40px rgba(26,58,92,0.15);
}

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background: var(--gray-50);
  color: var(--gray-800);
  line-height: 1.6;
}

/* ─── TEAM CIRCLE ─── */
.team-circle {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.7rem;
  font-weight: 800;
  color: white;
  flex-shrink: 0;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  box-shadow: 0 2px 6px rgba(0,0,0,0.18);
}
.team-circle.small { width: 24px; height: 24px; font-size: 0.55rem; }

/* ─── HERO ─── */
.hero {
  background: linear-gradient(135deg, #0f2b46 0%, #1a5276 40%, #1e8449 100%);
  color: var(--white);
  padding: 3rem 2rem 2.5rem;
  position: relative;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  top: -60%; right: -20%;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(237,137,54,0.3) 0%, transparent 70%);
  border-radius: 50%;
}
.hero::after {
  content: '';
  position: absolute;
  bottom: -40%; left: -10%;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(236,201,75,0.2) 0%, transparent 70%);
  border-radius: 50%;
}
.hero-inner {
  max-width: 1280px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 999px;
  padding: 4px 14px;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.hero-badge .dot {
  width: 8px; height: 8px;
  background: #68d391;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.4); }
}
.hero h1 {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: clamp(2rem, 5vw, 3.2rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin-bottom: 0.5rem;
}
.hero h1 span { color: var(--yellow-stadium); }
.hero p {
  font-size: 1.05rem;
  opacity: 0.85;
  max-width: 600px;
}
.hero-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}
.hero-stat { text-align: center; }
.hero-stat .num {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--yellow-stadium);
}
.hero-stat .label {
  font-size: 0.72rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  opacity: 0.7;
}
.countdown {
  margin-top: 1rem;
  font-size: 0.85rem;
  opacity: 0.8;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.countdown .cd-num {
  font-family: 'Oswald', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--yellow-stadium);
}

/* ─── PROGRESS BAR ─── */
.progress-section {
  max-width: 1280px;
  margin: -1.5rem auto 0;
  padding: 0 1.5rem;
  position: relative;
  z-index: 2;
}
.progress-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  padding: 1.25rem 1.5rem;
}
.progress-label {
  display: flex;
  justify-content: space-between;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--gray-600);
  margin-bottom: 0.5rem;
}
.progress-bar {
  height: 10px;
  background: var(--gray-200);
  border-radius: 999px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 999px;
  background: linear-gradient(90deg, var(--blue-mid), var(--green-light));
  transition: width 0.5s ease;
}

/* ─── TAB NAV ─── */
.tab-nav {
  max-width: 1280px;
  margin: 1.5rem auto 0;
  padding: 0 1.5rem;
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.tab-btn {
  padding: 0.6rem 1.25rem;
  border: none;
  border-radius: 999px;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  background: var(--white);
  color: var(--gray-600);
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  transition: all 0.2s;
}
.tab-btn:hover { color: var(--blue-mid); transform: translateY(-1px); }
.tab-btn.active {
  background: var(--blue-deep);
  color: var(--white);
}
.tab-content { display: none; }
.tab-content.active { display: block; }

/* ─── CONTAINER ─── */
.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 1.5rem 1.5rem 4rem;
}

/* ─── SECTION TITLES ─── */
.section-title {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: 1.45rem;
  font-weight: 700;
  color: var(--blue-deep);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.section-title .icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1rem;
  color: white;
}
.section-title .icon.orange { background: linear-gradient(135deg, var(--orange-gold), var(--orange-light)); }
.section-title .icon.blue   { background: linear-gradient(135deg, var(--blue-mid), var(--blue-light)); }
.section-title .icon.green  { background: linear-gradient(135deg, var(--green-pitch), var(--green-light)); }
.section-title .icon.red    { background: linear-gradient(135deg, #c53030, #fc8181); }
.section-title .icon.gold   { background: linear-gradient(135deg, #b7791f, #ecc94b); }

/* ─── MATCH CARDS ─── */
.result-subtitle {
  font-size: 0.85rem;
  color: var(--gray-600);
  margin-bottom: 1rem;
  padding-left: 0.1rem;
}
.matches-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1rem;
  margin-bottom: 3rem;
}
.match-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}
.match-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}
.match-card-header {
  padding: 0.6rem 1rem;
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: white;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.match-card-header.r32 { background: linear-gradient(90deg, #c53030, #fc8181); }
.match-card-header.r16 { background: linear-gradient(90deg, #b7791f, #ecc94b); }
.match-card-header.qf  { background: linear-gradient(90deg, #2b6cb0, #4299e1); }
.match-card-header.sf  { background: linear-gradient(90deg, #dd6b20, #ed8936); }
.match-card-header.f   { background: linear-gradient(90deg, #805ad5, #b794f4); }
.match-card-header.g-a { background: linear-gradient(90deg, #2b6cb0, #4299e1); }
.match-card-header.g-b { background: linear-gradient(90deg, #2f855a, #48bb78); }
.match-card-header.g-c { background: linear-gradient(90deg, #dd6b20, #ed8936); }
.match-card-header.g-d { background: linear-gradient(90deg, #805ad5, #b794f4); }
.match-card-header.g-e { background: linear-gradient(90deg, #c53030, #fc8181); }
.match-card-header.g-f { background: linear-gradient(90deg, #2c7a7b, #4fd1c5); }
.match-card-header.g7  { background: linear-gradient(90deg, #b7791f, #d69e2e); }
.match-card-header.g8  { background: linear-gradient(90deg, #38a169, #68d391); }
.match-card-header.g9  { background: linear-gradient(90deg, #3182ce, #63b3ed); }
.match-card-header.g10 { background: linear-gradient(90deg, #b7791f, #ecc94b); }
.match-card-header.g11 { background: linear-gradient(90deg, #e53e3e, #fc8181); }
.match-card-header.g12 { background: linear-gradient(90deg, #805ad5, #b794f4); }

.match-card-body { padding: 0.8rem 1rem 1rem; }

.match-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.55rem 0;
}
.match-row + .match-row { border-top: 1px solid var(--gray-100); }
.team {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  flex: 1;
  min-width: 0;
}
.team.away { justify-content: flex-end; text-align: right; }
.team-name {
  font-weight: 600;
  font-size: 0.88rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.score {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--blue-deep);
  min-width: 56px;
  text-align: center;
  background: var(--gray-100);
  border-radius: 8px;
  padding: 2px 6px;
  letter-spacing: 0.05em;
}
.winner .team-name { color: var(--green-pitch); }
.penalty-note {
  font-size: 0.68rem;
  color: var(--gray-600);
  margin-top: 0.15rem;
  font-style: italic;
}
.status {
  font-size: 0.68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 2px 8px;
  border-radius: 999px;
  display: inline-block;
  margin-top: 0.3rem;
}
.status.draw { color: var(--orange-gold); background: rgba(221,107,32,0.1); }
.status.win  { color: var(--green-pitch); background: rgba(47,133,90,0.1); }
.status.upcoming { color: var(--blue-mid); background: rgba(43,108,176,0.1); }
.status.advanced { color: var(--green-pitch); background: rgba(47,133,90,0.1); }

/* ─── STATS BAR ─── */
.stats-bar {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
  gap: 1rem;
  margin-bottom: 3rem;
}
.stat-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 1.25rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.stat-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
}
.stat-card:nth-child(1)::before { background: linear-gradient(90deg, #4299e1, #63b3ed); }
.stat-card:nth-child(2)::before { background: linear-gradient(90deg, #ed8936, #f6ad55); }
.stat-card:nth-child(3)::before { background: linear-gradient(90deg, #48bb78, #68d391); }
.stat-card:nth-child(4)::before { background: linear-gradient(90deg, #ecc94b, #f6e05e); }
.stat-card:nth-child(5)::before { background: linear-gradient(90deg, #e53e3e, #fc8181); }
.stat-card:nth-child(6)::before { background: linear-gradient(90deg, #b794f4, #d6bcfa); }
.stat-value {
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: 2.2rem;
  font-weight: 700;
  color: var(--blue-deep);
}
.stat-label {
  font-size: 0.76rem;
  color: var(--gray-600);
  margin-top: 0.2rem;
}

/* ─── TOP SCORERS ─── */
.scorers-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1rem;
  margin-bottom: 3rem;
}
.scorer-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 1rem 1.25rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  transition: transform 0.2s, box-shadow 0.2s;
}
.scorer-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}
.scorer-rank {
  font-family: 'Oswald', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--gray-400);
  min-width: 30px;
  text-align: center;
}
.scorer-rank.gold { color: #b7791f; }
.scorer-rank.silver { color: #718096; }
.scorer-rank.bronze { color: #c05621; }
.scorer-info { flex: 1; min-width: 0; }
.scorer-name {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--blue-deep);
}
.scorer-team {
  font-size: 0.78rem;
  color: var(--gray-600);
}
.scorer-goals {
  font-family: 'Oswald', sans-serif;
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--orange-gold);
  min-width: 40px;
  text-align: right;
}
.scorer-goals-label {
  font-size: 0.6rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-400);
  text-align: right;
}

/* ─── VENUE CARDS ─── */
.venues-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 1rem;
  margin-bottom: 3rem;
}
.venue-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}
.venue-card:hover {
  transform: translateY(-2px);
  box-shadow: var(--shadow-lg);
}
.venue-card-accent {
  height: 6px;
  background: linear-gradient(90deg, var(--blue-mid), var(--green-light));
}
.venue-card-accent.host {
  background: linear-gradient(90deg, var(--orange-gold), var(--yellow-stadium));
}
.venue-card-body { padding: 1rem 1.25rem; }
.venue-name {
  font-weight: 700;
  font-size: 1rem;
  color: var(--blue-deep);
  margin-bottom: 0.25rem;
}
.venue-city {
  font-size: 0.82rem;
  color: var(--gray-600);
  margin-bottom: 0.5rem;
}
.venue-details {
  display: flex;
  gap: 1rem;
  font-size: 0.75rem;
  color: var(--gray-400);
}
.venue-detail { display: flex; align-items: center; gap: 0.25rem; }
.venue-host-badge {
  display: inline-block;
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  padding: 1px 6px;
  border-radius: 4px;
  background: rgba(221,107,32,0.1);
  color: var(--orange-gold);
  margin-left: 0.5rem;
}

/* ─── TOURNAMENT TIMELINE ─── */
.timeline {
  position: relative;
  padding-left: 2rem;
  margin-bottom: 3rem;
}
.timeline::before {
  content: '';
  position: absolute;
  left: 8px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--blue-mid), var(--green-light), var(--orange-gold));
}
.timeline-item {
  position: relative;
  padding-bottom: 1.5rem;
}
.timeline-item::before {
  content: '';
  position: absolute;
  left: -1.65rem;
  top: 0.35rem;
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid var(--blue-mid);
  background: var(--white);
}
.timeline-item.past::before {
  background: var(--blue-mid);
  border-color: var(--blue-mid);
}
.timeline-item.current::before {
  background: var(--green-light);
  border-color: var(--green-light);
  box-shadow: 0 0 0 4px rgba(72,187,120,0.2);
}
.timeline-item.upcoming::before {
  background: var(--white);
  border-color: var(--gray-400);
}
.timeline-date {
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--gray-600);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.timeline-title {
  font-weight: 700;
  font-size: 1rem;
  color: var(--blue-deep);
}
.timeline-desc {
  font-size: 0.82rem;
  color: var(--gray-600);
  margin-top: 0.15rem;
}

/* ─── GROUP STANDINGS ─── */
.groups-wrapper {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
  gap: 1.25rem;
  margin-bottom: 3rem;
}
.group-card {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.group-card-header {
  padding: 0.65rem 1rem;
  font-family: 'Oswald', 'Impact', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.group-card-header .status-badge {
  font-family: 'Inter', sans-serif;
  font-size: 0.62rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  padding: 2px 8px;
  border-radius: 999px;
  background: rgba(255,255,255,0.2);
}
.g1  { background: linear-gradient(90deg, #2b6cb0, #4299e1); }
.g2  { background: linear-gradient(90deg, #2f855a, #48bb78); }
.g3  { background: linear-gradient(90deg, #dd6b20, #ed8936); }
.g4  { background: linear-gradient(90deg, #805ad5, #b794f4); }
.g5  { background: linear-gradient(90deg, #c53030, #fc8181); }
.g6  { background: linear-gradient(90deg, #2c7a7b, #4fd1c5); }
.g7  { background: linear-gradient(90deg, #b7791f, #d69e2e); }
.g8  { background: linear-gradient(90deg, #38a169, #68d391); }
.g9  { background: linear-gradient(90deg, #3182ce, #63b3ed); }
.g10 { background: linear-gradient(90deg, #b7791f, #ecc94b); }
.g11 { background: linear-gradient(90deg, #e53e3e, #fc8181); }
.g12 { background: linear-gradient(90deg, #805ad5, #b794f4); }

.standings-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.8rem;
}
.standings-table thead th {
  padding: 0.4rem 0.35rem;
  text-align: center;
  font-weight: 700;
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--gray-600);
  border-bottom: 2px solid var(--gray-200);
}
.standings-table thead th:first-child,
.standings-table thead th:nth-child(2) { text-align: left; }
.standings-table tbody td {
  padding: 0.5rem 0.35rem;
  text-align: center;
  border-bottom: 1px solid var(--gray-100);
  font-size: 0.8rem;
}
.standings-table tbody td:first-child {
  text-align: center;
  width: 22px;
  font-weight: 700;
  color: var(--gray-600);
  font-size: 0.72rem;
}
.standings-table tbody td:nth-child(2) { text-align: left; }
.standings-table tbody tr:last-child td { border-bottom: none; }
.standings-table tbody tr.qualifier { background: rgba(72,187,120,0.07); }
.standings-table tbody tr.best-third { background: rgba(221,107,32,0.06); }
.standings-table tbody tr.eliminated { opacity: 0.45; }
.team-cell {
  display: flex;
  align-items: center;
  gap: 0.4rem;
}
.pts { font-weight: 700; color: var(--blue-deep); }
.q-badge {
  display: inline-block;
  font-size: 0.58rem;
  font-weight: 700;
  color: var(--green-pitch);
  background: rgba(72,187,120,0.15);
  padding: 1px 5px;
  border-radius: 4px;
  margin-left: 4px;
}

/* ─── KNOCKOUT BRACKET ─── */
.bracket-section { margin-bottom: 3rem; }
.bracket-container {
  background: var(--white);
  border-radius: var(--radius);
  box-shadow: var(--shadow-lg);
  padding: 1.5rem;
  overflow-x: auto;
}
.bracket-table-wrap { min-width: 700px; overflow-x: auto; }
.bracket-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.bracket-table th {
  font-family: 'Oswald', sans-serif;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--blue-deep);
  padding: 0.5rem 0.5rem;
  text-align: center;
  border-bottom: 2px solid var(--gray-200);
}
.bracket-table td {
  padding: 0.3rem 0.5rem;
  vertical-align: top;
  border-bottom: 1px solid var(--gray-100);
}
.bracket-match {
  background: var(--gray-50);
  border-radius: 6px;
  padding: 0.4rem 0.5rem;
  margin-bottom: 0.3rem;
  font-size: 0.78rem;
}
.bracket-match .bm-teams { display: flex; flex-direction: column; gap: 2px; }
.bracket-match .bm-team {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4px;
}
.bracket-match .bm-team.winner { font-weight: 700; }
.bracket-match .bm-team .bm-circle {
  width: 18px; height: 18px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.5rem;
  font-weight: 800;
  color: white;
  flex-shrink: 0;
}
.bracket-match .bm-team .bm-name { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.bracket-match .bm-team .bm-score { font-weight: 700; font-family: 'Oswald', sans-serif; min-width: 18px; text-align: right; }
.bracket-match .bm-tbd { color: var(--gray-400); font-style: italic; font-size: 0.72rem; padding: 0.15rem 0; }
.bracket-match .bm-pens { font-size: 0.62rem; color: var(--gray-600); font-style: italic; margin-top: 2px; }
.bracket-connector {
  display: inline-block;
  width: 24px;
  text-align: center;
  color: var(--gray-400);
  font-size: 1rem;
  vertical-align: middle;
}

/* ─── ELIMINATED ─── */
.eliminated-section { margin-bottom: 3rem; }
.eliminated-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.eliminated-tag {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  background: var(--gray-100);
  border-radius: 999px;
  padding: 0.3rem 0.75rem;
  font-size: 0.78rem;
  color: var(--gray-600);
}
.eliminated-tag .et-circle {
  width: 16px; height: 16px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.45rem;
  font-weight: 800;
  color: white;
}

/* ─── FOOTER ─── */
.footer {
  text-align: center;
  padding: 2rem;
  font-size: 0.78rem;
  color: var(--gray-600);
  border-top: 1px solid var(--gray-200);
}

@media (max-width: 768px) {
  .hero { padding: 2rem 1rem 1.5rem; }
  .container { padding: 1.5rem 1rem 3rem; }
  .matches-grid { grid-template-columns: 1fr; }
  .groups-wrapper { grid-template-columns: 1fr 1fr; }
  .hero-stats { gap: 1.5rem; }
  .tab-nav { padding: 0 1rem; }
  .venues-grid { grid-template-columns: 1fr; }
  .scorers-grid { grid-template-columns: 1fr; }
}
@media (max-width: 560px) {
  .groups-wrapper { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<header class="hero">
  <div class="hero-inner">
    <div class="hero-badge"><span class="dot"></span> Live — July 2, 2026</div>
    <h1>FIFA World Cup <span>2026</span></h1>
    <p>Canada · Mexico · USA — Round of 32 Underway</p>
    <div class="countdown" id="countdown"></div>
    <div class="hero-stats">
      <div class="hero-stat"><div class="num">48</div><div class="label">Teams</div></div>
      <div class="hero-stat"><div class="num">84</div><div class="label">Matches Played</div></div>
      <div class="hero-stat"><div class="num">192</div><div class="label">Total Goals</div></div>
      <div class="hero-stat"><div class="num">20</div><div class="label">Matches Left</div></div>
      <div class="hero-stat"><div class="num">20</div><div class="label">Teams Left</div></div>
    </div>
  </div>
</header>

<!-- Tournament Progress -->
<div class="progress-section">
  <div class="progress-card">
    <div class="progress-label">
      <span>Tournament Progress</span>
      <span>84 / 104 matches</span>
    </div>
    <div class="progress-bar">
      <div class="progress-fill" style="width: 80.8%"></div>
    </div>
  </div>
</div>

<!-- Tab Navigation -->
<nav class="tab-nav" id="tabNav">
  <button class="tab-btn active" data-tab="knockout">⚔️ Knockout</button>
  <button class="tab-btn" data-tab="groupstage">🏟️ Group Stage</button>
  <button class="tab-btn" data-tab="standings">📊 Standings</button>
  <button class="tab-btn" data-tab="upcoming">📅 Upcoming</button>
  <button class="tab-btn" data-tab="scorers">⚽ Top Scorers</button>
  <button class="tab-btn" data-tab="venues">🏟️ Venues</button>
  <button class="tab-btn" data-tab="timeline">📋 Timeline</button>
</nav>

<main class="container">

  <!-- ═══ TAB 1: KNOCKOUT ═══ -->
  <div class="tab-content active" id="tab-knockout">

    <!-- Round of 32: Completed -->
    <section>
      <h2 class="section-title"><span class="icon red">⚔</span> Round of 32 — Results</h2>
      <p class="result-subtitle">June 28 – July 2 · 12 of 16 matches completed</p>
      <div class="matches-grid" id="r32Results"></div>
    </section>

    <!-- Round of 32: Upcoming -->
    <section>
      <h2 class="section-title"><span class="icon orange">⏳</span> Round of 32 — Upcoming</h2>
      <p class="result-subtitle">July 2 – 3 · 4 matches remaining</p>
      <div class="matches-grid" id="r32Upcoming"></div>
    </section>

    <!-- Round of 16 -->
    <section>
      <h2 class="section-title"><span class="icon blue">🏆</span> Round of 16 — Projected Bracket</h2>
      <p style="font-size:0.88rem;color:var(--gray-600);margin-bottom:1rem;">
        Winners of the Round of 32 advance. Bracket fills in as results come in.
      </p>
      <div class="bracket-container">
        <div class="bracket-table-wrap" id="r16Bracket"></div>
      </div>
    </section>

  </div>

  <!-- ═══ TAB 2: GROUP STAGE ═══ -->
  <div class="tab-content" id="tab-groupstage">
    <section>
      <h2 class="section-title"><span class="icon green">✓</span> Group Stage — All Results</h2>
      <p class="result-subtitle">June 11 – 27 · 72 matches · All 12 groups concluded</p>
      <div class="matches-grid" id="groupResults"></div>
    </section>
  </div>

  <!-- ═══ TAB 3: STANDINGS ═══ -->
  <div class="tab-content" id="tab-standings">
    <section>
      <h2 class="section-title"><span class="icon green">♛</span> Final Group Standings</h2>
      <p style="font-size:0.85rem;color:var(--gray-600);margin-bottom:1rem;">
        Top 2 from each group + 8 best third-place teams advance to Round of 32.
      </p>
      <div class="groups-wrapper" id="groupsWrapper"></div>
    </section>

    <!-- Eliminated Teams -->
    <section class="eliminated-section">
      <h2 class="section-title"><span class="icon red">✕</span> Eliminated in Round of 32</h2>
      <p style="font-size:0.85rem;color:var(--gray-600);margin-bottom:1rem;">
        These teams have been knocked out of the tournament.
      </p>
      <div class="eliminated-grid" id="eliminatedGrid"></div>
    </section>

    <!-- Eliminated at Group Stage -->
    <section class="eliminated-section">
      <h2 class="section-title"><span class="icon red">✕</span> Eliminated at Group Stage</h2>
      <p style="font-size:0.85rem;color:var(--gray-600);margin-bottom:1rem;">
        These teams did not advance out of their groups.
      </p>
      <div class="eliminated-grid" id="groupEliminatedGrid"></div>
    </section>
  </div>

  <!-- ═══ TAB 4: UPCOMING ═══ -->
  <div class="tab-content" id="tab-upcoming">
    <section>
      <h2 class="section-title"><span class="icon orange">📅</span> Remaining Fixtures</h2>
      <p style="font-size:0.88rem;color:var(--gray-600);margin-bottom:1.5rem;">
        All dates and venues for the rest of the tournament.
      </p>
      <div class="matches-grid" id="upcomingMatches"></div>
    </section>
  </div>

  <!-- ═══ TAB 5: TOP SCORERS ═══ -->
  <div class="tab-content" id="tab-scorers">
    <section>
      <h2 class="section-title"><span class="icon gold">⚽</span> Top Goal Scorers</h2>
      <p style="font-size:0.88rem;color:var(--gray-600);margin-bottom:1.5rem;">
        Leading goalscorers through the Round of 32.
      </p>
      <div class="scorers-grid" id="scorersGrid"></div>
    </section>
  </div>

  <!-- ═══ TAB 6: VENUES ═══ -->
  <div class="tab-content" id="tab-venues">
    <section>
      <h2 class="section-title"><span class="icon blue">🏟️</span> Stadiums &amp; Host Cities</h2>
      <p style="font-size:0.88rem;color:var(--gray-600);margin-bottom:1.5rem;">
        16 venues across 3 countries — the largest World Cup footprint in history.
      </p>
      <div class="venues-grid" id="venuesGrid"></div>
    </section>
  </div>

  <!-- ═══ TAB 7: TIMELINE ═══ -->
  <div class="tab-content" id="tab-timeline">
    <section>
      <h2 class="section-title"><span class="icon green">📋</span> Tournament Timeline</h2>
      <p style="font-size:0.88rem;color:var(--gray-600);margin-bottom:1.5rem;">
        Key dates and milestones from opening match to the Final.
      </p>
      <div class="timeline" id="timelineContainer"></div>
    </section>
  </div>

</main>

<footer class="footer">
  Data as of July 2, 2026 · Sources: CBS Sports, Olympics.com, FIFA.com · Built for fans
</footer>

