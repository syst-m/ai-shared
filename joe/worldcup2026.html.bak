/* ================================================================
   RENDER HELPERS
   ================================================================ */
function renderKnockoutMatch(m, headerClass, headerText) {
  var card = document.createElement('div');
  card.className = 'match-card';

  var header = document.createElement('div');
  header.className = 'match-card-header ' + headerClass;
  header.textContent = headerText;

  var body = document.createElement('div');
  body.className = 'match-card-body';

  var homeWin = m.winner === m.home;
  var draw = m.hsc !== null && m.hsc === m.ascore;

  // Home team
  var row1 = document.createElement('div');
  row1.className = 'match-row' + (homeWin ? ' winner' : '');
  var hCircle = document.createElement('span');
  hCircle.className = 'team-circle small';
  hCircle.style.background = teamColor(m.home);
  hCircle.textContent = teamInitials(m.home);
  var hName = document.createElement('span');
  hName.className = 'team-name';
  hName.textContent = m.home;
  row1.appendChild(hCircle);
  row1.appendChild(hName);

  var score = document.createElement('span');
  score.className = 'score';
  score.textContent = m.hsc !== null ? (m.hsc + ' – ' + m.ascore) : 'v';

  var row2 = document.createElement('div');
  row2.className = 'match-row away';
  var aName = document.createElement('span');
  aName.className = 'team-name';
  aName.textContent = m.away;
  var aCircle = document.createElement('span');
  aCircle.className = 'team-circle small';
  aCircle.style.background = teamColor(m.away);
  aCircle.textContent = teamInitials(m.away);
  row2.appendChild(aName);
  row2.appendChild(aCircle);

  body.appendChild(row1);
  body.appendChild(score);
  body.appendChild(row2);

  // Extra info
  var info = document.createElement('div');
  info.style.textAlign = 'center';
  if (m.winner) {
    var st = document.createElement('span');
    st.className = 'status win';
    st.textContent = '★ ' + m.winner + ' advances';
    info.appendChild(st);
    if (m.pens) {
      var pen = document.createElement('div');
      pen.className = 'penalty-note';
      pen.textContent = 'Won ' + m.pens + ' on penalties';
      info.appendChild(pen);
    }
  } else if (m.hsc === null) {
    var st = document.createElement('span');
    st.className = 'status upcoming';
    st.textContent = 'Upcoming';
    info.appendChild(st);
  }
  body.appendChild(info);

  // Venue
  if (m.venue) {
    var venue = document.createElement('div');
    venue.style.cssText = 'font-size:0.68rem;color:var(--gray-400);text-align:center;margin-top:0.2rem;';
    venue.textContent = '📍 ' + m.venue;
    body.appendChild(venue);
  }

  card.appendChild(header);
  card.appendChild(body);
  return card;
}

/* ================================================================
   RENDER: ROUND OF 32 RESULTS
   ================================================================ */
(function renderR32Results() {
  var grid = document.getElementById('r32Results');
  if (!grid) return;

  for (var i = 0; i < r32Completed.length; i++) {
    var m = r32Completed[i];
    grid.appendChild(renderKnockoutMatch(m, 'r32', 'Round of 32 — ' + m.date));
  }
})();

/* ================================================================
   RENDER: ROUND OF 32 UPCOMING
   ================================================================ */
(function renderR32Upcoming() {
  var grid = document.getElementById('r32Upcoming');
  if (!grid) return;

  for (var i = 0; i < r32Upcoming.length; i++) {
    var m = r32Upcoming[i];
    grid.appendChild(renderKnockoutMatch(m, 'r32', 'Round of 32 — ' + m.date));
  }
})();

/* ================================================================
   RENDER: ROUND OF 16 BRACKET (HTML table)
   ================================================================ */
(function renderR16Bracket() {
  var container = document.getElementById('r16Bracket');
  if (!container) return;

  var html = '<table class="bracket-table"><thead><tr>';
  html += '<th>#</th><th>Matchup</th><th>Date</th><th>Venue</th>';
  html += '</tr></thead><tbody>';

  for (var i = 0; i < r16Bracket.length; i++) {
    var m = r16Bracket[i];
    html += '<tr>';
    html += '<td style="font-weight:700;color:var(--gray-600);">' + m.slot + '</td>';

    // Matchup cell
    html += '<td><div class="bracket-match"><div class="bm-teams">';

    // Home team
    if (m.w1.indexOf('/') === -1) {
      html += '<div class="bm-team winner">';
      html += '<span class="bm-circle" style="background:' + teamColor(m.w1) + '">' + teamInitials(m.w1) + '</span>';
      html += '<span class="bm-name">' + m.w1 + '</span>';
      html += '</div>';
    } else {
      var parts = m.w1.split('/');
      html += '<div class="bm-tbd">';
      html += '<span class="bm-circle" style="background:' + teamColor(parts[0]) + '">' + teamInitials(parts[0]) + '</span>';
      html += ' vs ';
      html += '<span class="bm-circle" style="background:' + teamColor(parts[1]) + '">' + teamInitials(parts[1]) + '</span>';
      html += '</div>';
    }

    // Away team
    if (m.w2.indexOf('/') === -1) {
      html += '<div class="bm-team winner">';
      html += '<span class="bm-circle" style="background:' + teamColor(m.w2) + '">' + teamInitials(m.w2) + '</span>';
      html += '<span class="bm-name">' + m.w2 + '</span>';
      html += '</div>';
    } else {
      var parts2 = m.w2.split('/');
      html += '<div class="bm-tbd">';
      html += '<span class="bm-circle" style="background:' + teamColor(parts2[0]) + '">' + teamInitials(parts2[0]) + '</span>';
      html += ' vs ';
      html += '<span class="bm-circle" style="background:' + teamColor(parts2[1]) + '">' + teamInitials(parts2[1]) + '</span>';
      html += '</div>';
    }

    html += '</div></div></td>';

    // Date
    html += '<td>' + m.date + '</td>';

    // Venue
    html += '<td style="font-size:0.75rem;color:var(--gray-600);">' + m.venue + '</td>';
    html += '</tr>';
  }

  html += '</tbody></table>';
  container.innerHTML = html;
})();

/* ================================================================
   RENDER: GROUP STAGE RESULTS (grouped by matchday)
   ================================================================ */
(function renderGroupResults() {
  var grid = document.getElementById('groupResults');
  if (!grid) return;

  var byDate = {};
  for (var i = 0; i < groupMatches.length; i++) {
    var d = groupMatches[i].date;
    if (!byDate[d]) byDate[d] = [];
    byDate[d].push(groupMatches[i]);
  }

  var dates = [];
  for (var key in byDate) { if (byDate.hasOwnProperty(key)) dates.push(key); }
  dates.sort();

  var clsMap = {'A':'g-a','B':'g-b','C':'g-c','D':'g-d','E':'g-e','F':'g-f',
                'G':'g7','H':'g8','I':'g9','J':'g10','K':'g11','L':'g12'};

  for (var di = 0; di < dates.length; di++) {
    var date = dates[di];
    var matches = byDate[date];

    var byGroup = {};
    for (var mi = 0; mi < matches.length; mi++) {
      var g = matches[mi].group;
      if (!byGroup[g]) byGroup[g] = [];
      byGroup[g].push(matches[mi]);
    }

    var groupKeys = [];
    for (var gk in byGroup) { if (byGroup.hasOwnProperty(gk)) groupKeys.push(gk); }
    groupKeys.sort();

    for (var gki = 0; gki < groupKeys.length; gki++) {
      var g = groupKeys[gki];
      var gMatches = byGroup[g];

      var card = document.createElement('div');
      card.className = 'match-card';

      var header = document.createElement('div');
      header.className = 'match-card-header ' + clsMap[g];
      header.textContent = 'Group ' + g + ' — ' + date;

      var body = document.createElement('div');
      body.className = 'match-card-body';

      for (var mki = 0; mki < gMatches.length; mki++) {
        var m = gMatches[mki];
        var row1 = document.createElement('div');
        row1.className = 'match-row';
        var hCircle = document.createElement('span');
        hCircle.className = 'team-circle small';
        hCircle.style.background = teamColor(m.home);
        hCircle.textContent = teamInitials(m.home);
        var hName = document.createElement('span');
        hName.className = 'team-name';
        hName.textContent = m.home;
        row1.appendChild(hCircle);
        row1.appendChild(hName);

        var score = document.createElement('span');
        score.className = 'score';
        score.textContent = m.hsc + ' – ' + m.ascore;

        var row2 = document.createElement('div');
        row2.className = 'match-row away';
        var aName = document.createElement('span');
        aName.className = 'team-name';
        aName.textContent = m.away;
        var aCircle = document.createElement('span');
        aCircle.className = 'team-circle small';
        aCircle.style.background = teamColor(m.away);
        aCircle.textContent = teamInitials(m.away);
        row2.appendChild(aName);
        row2.appendChild(aCircle);

        body.appendChild(row1);
        body.appendChild(score);
        body.appendChild(row2);
      }

      card.appendChild(header);
      card.appendChild(body);
      grid.appendChild(card);
    }
  }
})();

/* ================================================================
   RENDER: GROUP STANDINGS
   ================================================================ */
(function renderGroups() {
  var wrapper = document.getElementById('groupsWrapper');
  if (!wrapper) return;

  for (var gi = 0; gi < groups.length; gi++) {
    var g = groups[gi];
    var card = document.createElement('div');
    card.className = 'group-card';

    var header = document.createElement('div');
    header.className = 'group-card-header ' + g.cls;
    var title = document.createElement('span');
    title.textContent = 'Group ' + g.letter;
    var badge = document.createElement('span');
    badge.className = 'status-badge';
    badge.textContent = 'Complete';
    header.appendChild(title);
    header.appendChild(badge);

    var table = document.createElement('table');
    table.className = 'standings-table';

    var thead = document.createElement('thead');
    var headRow = document.createElement('tr');
    var headers = ['#','Team','P','W','D','L','GD','GF','Pts'];
    for (var h = 0; h < headers.length; h++) {
      var th = document.createElement('th');
      th.textContent = headers[h];
      headRow.appendChild(th);
    }
    thead.appendChild(headRow);
    table.appendChild(thead);

    var tbody = document.createElement('tbody');
    for (var ti = 0; ti < g.teams.length; ti++) {
      var t = g.teams[ti];
      var tr = document.createElement('tr');
      if (t.qa) tr.className = 'qualifier';
      else if (t.elim) tr.className = 'eliminated';

      var tdPos = document.createElement('td');
      tdPos.textContent = ti + 1;
      tr.appendChild(tdPos);

      var tdTeam = document.createElement('td');
      var teamCell = document.createElement('div');
      teamCell.className = 'team-cell';
      var circle = document.createElement('span');
      circle.className = 'team-circle small';
      circle.style.background = teamColor(t.name);
      circle.textContent = teamInitials(t.name);
      var nameSpan = document.createElement('span');
      nameSpan.className = 'team-name';
      nameSpan.textContent = t.name;
      teamCell.appendChild(circle);
      teamCell.appendChild(nameSpan);
      if (t.qa) {
        var qBadge = document.createElement('span');
        qBadge.className = 'q-badge';
        qBadge.textContent = 'Q';
        teamCell.appendChild(qBadge);
      }
      tdTeam.appendChild(teamCell);
      tr.appendChild(tdTeam);

      var fields = ['gp','w','d','l'];
      for (var f = 0; f < fields.length; f++) {
        var td = document.createElement('td');
        td.textContent = t[fields[f]];
        tr.appendChild(td);
      }
      var tdGD = document.createElement('td');
      tdGD.textContent = t.gd > 0 ? '+' + t.gd : t.gd;
      tr.appendChild(tdGD);
      var tdGF = document.createElement('td');
      tdGF.textContent = t.gf;
      tr.appendChild(tdGF);
      var tdPts = document.createElement('td');
      tdPts.className = 'pts';
      tdPts.textContent = t.pts;
      tr.appendChild(tdPts);

      tbody.appendChild(tr);
    }
    table.appendChild(tbody);
    card.appendChild(header);
    card.appendChild(table);
    wrapper.appendChild(card);
  }
})();

/* ================================================================
   RENDER: ELIMINATED TEAMS
   ================================================================ */
(function renderEliminated() {
  // R32 eliminated (12 teams knocked out)
  var r32Elim = ['South Africa','Japan','Paraguay','Morocco','Ivory Coast',
                 'Sweden','Ecuador','DR Congo','Senegal',
                 'Bosnia and Herzegovina','Austria','Croatia'];
  var grid1 = document.getElementById('eliminatedGrid');
  if (grid1) {
    for (var i = 0; i < r32Elim.length; i++) {
      var tag = document.createElement('span');
      tag.className = 'eliminated-tag';
      var circle = document.createElement('span');
      circle.className = 'et-circle';
      circle.style.background = teamColor(r32Elim[i]);
      circle.textContent = teamInitials(r32Elim[i]);
      tag.appendChild(circle);
      tag.appendChild(document.createTextNode(r32Elim[i]));
      grid1.appendChild(tag);
    }
  }

  // Group stage eliminated (15 teams)
  var groupElim = ['Qatar','Panama','Tunisia','Turkiye','Haiti','Jordan',
                   'Czechia','Curacao','Iraq','Uruguay','Saudi Arabia',
                   'New Zealand','Scotland','Uzbekistan','Iran'];
  var grid2 = document.getElementById('groupEliminatedGrid');
  if (grid2) {
    for (var i = 0; i < groupElim.length; i++) {
      var tag = document.createElement('span');
      tag.className = 'eliminated-tag';
      var circle = document.createElement('span');
      circle.className = 'et-circle';
      circle.style.background = teamColor(groupElim[i]);
      circle.textContent = teamInitials(groupElim[i]);
      tag.appendChild(circle);
      tag.appendChild(document.createTextNode(groupElim[i]));
      grid2.appendChild(tag);
    }
  }
})();

/* ================================================================
   RENDER: TOP SCORERS
   ================================================================ */
(function renderScorers() {
  var grid = document.getElementById('scorersGrid');
  if (!grid) return;

  for (var i = 0; i < topScorers.length; i++) {
    var s = topScorers[i];
    var card = document.createElement('div');
    card.className = 'scorer-card';

    var rank = document.createElement('div');
    rank.className = 'scorer-rank';
    if (i === 0) rank.className += ' gold';
    else if (i === 1) rank.className += ' silver';
    else if (i === 2) rank.className += ' bronze';
    rank.textContent = '#' + (i + 1);

    var info = document.createElement('div');
    info.className = 'scorer-info';

    var name = document.createElement('div');
    name.className = 'scorer-name';
    name.textContent = s.name;

    var team = document.createElement('div');
    team.className = 'scorer-team';
    team.textContent = s.team;

    info.appendChild(name);
    info.appendChild(team);

    var goals = document.createElement('div');
    goals.style.textAlign = 'right';

    var goalsNum = document.createElement('div');
    goalsNum.className = 'scorer-goals';
    goalsNum.textContent = s.goals;

    var goalsLabel = document.createElement('div');
    goalsLabel.className = 'scorer-goals-label';
    goalsLabel.textContent = 'goals';

    goals.appendChild(goalsNum);
    goals.appendChild(goalsLabel);

    card.appendChild(rank);
    card.appendChild(info);
    card.appendChild(goals);
    grid.appendChild(card);
  }
})();

/* ================================================================
   RENDER: VENUES
   ================================================================ */
(function renderVenues() {
  var grid = document.getElementById('venuesGrid');
  if (!grid) return;

  for (var i = 0; i < venues.length; i++) {
    var v = venues[i];
    var card = document.createElement('div');
    card.className = 'venue-card';

    var accent = document.createElement('div');
    accent.className = 'venue-card-accent' + (v.host ? ' host' : '');

    var body = document.createElement('div');
    body.className = 'venue-card-body';

    var name = document.createElement('div');
    name.className = 'venue-name';
    name.textContent = v.name + (v.host ? '<span class="venue-host-badge">Host</span>' : '');
    name.innerHTML = v.name + (v.host ? '<span class="venue-host-badge">Host</span>' : '');

    var city = document.createElement('div');
    city.className = 'venue-city';
    city.textContent = v.city + ', ' + v.country;

    var details = document.createElement('div');
    details.className = 'venue-details';

    var cap = document.createElement('span');
    cap.className = 'venue-detail';
    cap.textContent = '👥 ' + v.capacity;

    var km = document.createElement('span');
    km.className = 'venue-detail';
    km.textContent = '📋 ' + v.keyMatches;

    details.appendChild(cap);
    details.appendChild(km);

    body.appendChild(name);
    body.appendChild(city);
    body.appendChild(details);

    card.appendChild(accent);
    card.appendChild(body);
    grid.appendChild(card);
  }
})();

/* ================================================================
   RENDER: TOURNAMENT TIMELINE
   ================================================================ */
(function renderTimeline() {
  var container = document.getElementById('timelineContainer');
  if (!container) return;

  for (var i = 0; i < timeline.length; i++) {
    var t = timeline[i];
    var item = document.createElement('div');
    item.className = 'timeline-item ' + t.status;

    var date = document.createElement('div');
    date.className = 'timeline-date';
    date.textContent = t.date;

    var title = document.createElement('div');
    title.className = 'timeline-title';
    title.textContent = t.title;

    var desc = document.createElement('div');
    desc.className = 'timeline-desc';
    desc.textContent = t.desc;

    item.appendChild(date);
    item.appendChild(title);
    item.appendChild(desc);
    container.appendChild(item);
  }
})();

/* ================================================================
   RENDER: UPCOMING FIXTURES
   ================================================================ */
(function renderUpcoming() {
  var grid = document.getElementById('upcomingMatches');
  if (!grid) return;

  // Combine R32 upcoming + R16
  var allUpcoming = [];

  for (var i = 0; i < r32Upcoming.length; i++) {
    allUpcoming.push({
      date: r32Upcoming[i].date,
      home: r32Upcoming[i].home,
      away: r32Upcoming[i].away,
      venue: r32Upcoming[i].venue,
      round: 'Round of 32'
    });
  }

  for (var i = 0; i < r16Bracket.length; i++) {
    allUpcoming.push({
      date: r16Bracket[i].date,
      home: r16Bracket[i].w1,
      away: r16Bracket[i].w2,
      venue: r16Bracket[i].venue,
      round: 'Round of 16'
    });
  }

  // Sort by date
  allUpcoming.sort(function(a, b) { return a.date.localeCompare(b.date); });

  for (var i = 0; i < allUpcoming.length; i++) {
    var m = allUpcoming[i];
    var card = document.createElement('div');
    card.className = 'match-card';

    var headerClass = m.round === 'Round of 32' ? 'r32' : 'r16';
    var header = document.createElement('div');
    header.className = 'match-card-header ' + headerClass;
    header.textContent = m.round + ' — ' + m.date;

    var body = document.createElement('div');
    body.className = 'match-card-body';

    // Home
    var row1 = document.createElement('div');
    row1.className = 'match-row';
    var hCircle = document.createElement('span');
    hCircle.className = 'team-circle small';
    var hColor = m.home.indexOf('/') === -1 ? teamColor(m.home) : '#a0aec0';
    hCircle.style.background = hColor;
    hCircle.textContent = m.home.indexOf('/') === -1 ? teamInitials(m.home) : '?';
    var hName = document.createElement('span');
    hName.className = 'team-name';
    hName.textContent = m.home;
    row1.appendChild(hCircle);
    row1.appendChild(hName);

    var score = document.createElement('span');
    score.className = 'score';
    score.textContent = 'v';

    var row2 = document.createElement('div');
    row2.className = 'match-row away';
    var aName = document.createElement('span');
    aName.className = 'team-name';
    aName.textContent = m.away;
    var aCircle = document.createElement('span');
    aCircle.className = 'team-circle small';
    var aColor = m.away.indexOf('/') === -1 ? teamColor(m.away) : '#a0aec0';
    aCircle.style.background = aColor;
    aCircle.textContent = m.away.indexOf('/') === -1 ? teamInitials(m.away) : '?';
    row2.appendChild(aName);
    row2.appendChild(aCircle);

    body.appendChild(row1);
    body.appendChild(score);
    body.appendChild(row2);

    var info = document.createElement('div');
    info.style.textAlign = 'center';
    var st = document.createElement('span');
    st.className = 'status upcoming';
    st.textContent = 'Upcoming';
    info.appendChild(st);
    body.appendChild(info);

    if (m.venue) {
      var venue = document.createElement('div');
      venue.style.cssText = 'font-size:0.68rem;color:var(--gray-400);text-align:center;margin-top:0.2rem;';
      venue.textContent = '📍 ' + m.venue;
      body.appendChild(venue);
    }

    card.appendChild(header);
    card.appendChild(body);
    grid.appendChild(card);
  }
})();

/* ================================================================
   COUNTDOWN TO FINAL
   ================================================================ */
(function countdown() {
  var el = document.getElementById('countdown');
  if (!el) return;

  var finalDate = new Date('2026-07-19T18:00:00-04:00');
  var now = new Date();
  var diff = finalDate - now;

  if (diff <= 0) {
    el.innerHTML = '🏆 <strong>Final played!</strong>';
    return;
  }

  var days = Math.floor(diff / (1000 * 60 * 60 * 24));
  var hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));

  el.innerHTML = '🏆 <span class="cd-num">' + days + '</span> days, <span class="cd-num">' + hours + '</span> hours until the Final at MetLife Stadium';
})();

/* ================================================================
   TAB NAVIGATION
   ================================================================ */
(function initTabs() {
  var nav = document.getElementById('tabNav');
  if (!nav) return;

  var buttons = nav.querySelectorAll('.tab-btn');
  for (var i = 0; i < buttons.length; i++) {
    buttons[i].addEventListener('click', function() {
      // Remove active from all buttons
      for (var j = 0; j < buttons.length; j++) {
        buttons[j].classList.remove('active');
      }
      // Hide all tab content
      var contents = document.querySelectorAll('.tab-content');
      for (var j = 0; j < contents.length; j++) {
        contents[j].classList.remove('active');
      }
      // Activate clicked tab
      this.classList.add('active');
      var tabId = 'tab-' + this.getAttribute('data-tab');
      document.getElementById(tabId).classList.add('active');
    });
  }
})();
</script>
</body>
</html>
