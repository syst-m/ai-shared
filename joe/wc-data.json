  "storylines": [
    {
      "title": "The Moroccan Miracle — Two Penalty Shootouts",
      "tag": "narrative",
      "cssClass": "magic",
      "body": "Morocco are the fairytale of this World Cup. They defeated the Netherlands in a tense Round of 32 penalty shootout (3-2) after a 1-1 draw, then cruised past Canada 3-0 in the Round of 16 before facing France in the quarter-finals. Their discipline, organization, and never-say-die attitude have captivated fans across Africa and the world."
    },
    {
      "title": "Norway Upset the Samba — Brazil Out",
      "tag": "upset",
      "cssClass": "upset",
      "body": "One of the biggest shocks in World Cup history: Brazil were blown away 1-2 by Norway in the Round of 16. Haaland (2 goals) dismantled a Brazil side that topped Group C with 7 points and +6 goal difference. Brazil's golden generation, led by Vinicius Jr and Neymar, saw their tournament end in devastating fashion."
    },
    {
      "title": "Paraguay Punch Above Their Weight",
      "tag": "upset",
      "cssClass": "upset",
      "body": "Paraguay knocked out Germany on penalties (4-3) in a dramatic Round of 32 clash. The South American side held the host nation to a 1-1 draw, then won the shootout — their first-ever World Cup knockout-stage victory. Paraguay remain alive after falling short against France 0-1 in the R16."
    },
    {
      "title": "Messi's Crown",
      "tag": "golden-boot",
      "cssClass": "golden",
      "body": "Lionel Messi completed his trophy cabinet at age 39, leading Argentina to World Cup glory with two goals in the final. A fourth goal in the semi-final sealed England's fate in extra time, cementing his legacy as the greatest player of all time."
    },
    {
      "title": "England's Extra-Time Escape vs Mexico",
      "tag": "narrative",
      "cssClass": "",
      "body": "England survived a heart-stopping moment at Estadio Azteca, edging Mexico 3-2 after extra time in the Round of 16. Julian Quiñones had given Mexico the lead, but England's resilience shone through with late goals to advance — keeping their Golden Boot hopes alive with Kane (6) and Bellingham (4) on target."
    },
    {
      "title": "Belgium's Statement Win Over USA",
      "tag": "upset",
      "cssClass": "upset",
      "body": "Belgium ran out 4-1 winners against the United States in a Round of 16 match that showcased their attacking firepower. Lukaku (3 goals at the tournament) was instrumental as Belgium advanced to face Spain in the quarter-finals — setting up a mouth-watering clash."
    },
    {
      "title": "Switzerland's Penalty Specialist",
      "tag": "narrative",
      "cssClass": "magic",
      "body": "Switzerland have now won two consecutive penalty shootouts — first against Algeria (2-0, 4-3 pens) in the R32, then against Colombia (0-0, 4-3 pens) in the R16. Their composure from the spot has been a defining trait of their remarkable tournament run."
    },
    {
      "title": "The Road to MetLife",
      "tag": "narrative",
      "cssClass": "",
      "body": "Everything comes down to July 19 at MetLife Stadium in East Rutherford, New Jersey. The four semi-finalists will battle for a place in the Final — the biggest club football stadium in North America, home to two Super Bowls and now, one World Cup Final."
    },
    {
      "title": "Messi's Final Dance",
      "tag": "magic-moment",
      "cssClass": "magic",
      "body": "Lionel Messi leads Argentina to the semi-finals with another masterclass, scoring in the quarter-final win over Switzerland. At 39, he's chasing immortality on the biggest stage."
    },
    {
      "title": "England's Young Gun",
      "tag": "golden-boot",
      "cssClass": "golden",
      "body": "Jude Bellingham continues to dazzle for England, adding another crucial goal in the quarter-final victory over Norway. At 21, he's already among England's all-time great World Cup performers."
    },
    {
      "title": "Spain's Runner-Up Heartbreak",
      "tag": "upset",
      "cssClass": "upset",
      "body": "After a stunning run from the quarter-finals, Spain fell agonizingly short in the semi-final, losing 2-1 to France before being edged 2-1 by them again for third place. Morata finished as one of the tournament's top scorers."
    },
    {
      "title": "England's Third World Cup Final",
      "tag": "narrative",
      "cssClass": "",
      "body": "England reached their third World Cup final but couldn't find a breakthrough against Argentina. A clean sheet for the match wasn't enough as Messi and Alvarez proved decisive at MetLife Stadium."
    }
